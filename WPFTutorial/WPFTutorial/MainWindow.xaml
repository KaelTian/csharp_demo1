<Window x:Class="WPFTutorial.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WPFTutorial.Controls"
        xmlns:converters="clr-namespace:WPFTutorial.Converters"
        Title="工业控制系统 HMI 监控面板"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <ResourceDictionary>
            <converters:DoubleToColorConverter x:Key="TempToColor" HighThreshold="80" />
            <converters:DoubleToColorConverter x:Key="PressureToColor" HighThreshold="1.2" />
            <converters:BoolToColorConverter x:Key="BoolToGreen" />
            <converters:BoolToColorConverter x:Key="BoolToRed" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacity" />
            <converters:DoubleToPercentConverter x:Key="DoubleToPct" />
            <converters:DoubleToAngleConverter x:Key="DoubleToAngle" MinAngle="-120" MaxAngle="120" />

            <Style x:Key="SectionTitle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#8899AA" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="CardBorder" TargetType="Border">
                <Setter Property="Background" Value="#151C24" />
                <Setter Property="BorderBrush" Value="#253040" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Border Grid.Row="0" Background="#1A2332" BorderBrush="#253040" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🏭" FontSize="20" VerticalAlignment="Center" />
                    <TextBlock Text="工业控制系统 HMI 监控面板"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#E8EDF2" Margin="8,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock x:Name="HeaderTime" Grid.Column="2"
                           Text="--"
                           Foreground="#8899AA" FontSize="12"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ===== PLC Connection Bar ===== -->
        <Border Grid.Row="1" Background="#0F1920" BorderBrush="#1A3040" BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse x:Name="plcStatusDot" Grid.Column="0" Width="10" Height="10"
                         Fill="#607080" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Grid.Column="1" Text="PLC" Foreground="#8899AA"
                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />

                <TextBlock Grid.Column="2" Text="IP:" Foreground="#607080" FontSize="11"
                           VerticalAlignment="Center" />
                <TextBox x:Name="plcIpBox" Grid.Column="3" Text="192.168.0.1" Width="110"
                         FontSize="11" FontFamily="Consolas" Background="#1A2332"
                         Foreground="#E8EDF2" BorderBrush="#253040" Padding="4,2"
                         VerticalAlignment="Center" Margin="4,0,8,0" />

                <TextBlock Grid.Column="4" Text="机架:" Foreground="#607080" FontSize="11"
                           VerticalAlignment="Center" />
                <TextBox x:Name="plcRackBox" Grid.Column="5" Text="0" Width="30"
                         FontSize="11" FontFamily="Consolas" Background="#1A2332"
                         Foreground="#E8EDF2" BorderBrush="#253040" Padding="4,2"
                         VerticalAlignment="Center" Margin="4,0,8,0" />

                <TextBlock Grid.Column="6" Text="槽位:" Foreground="#607080" FontSize="11"
                           VerticalAlignment="Center" />
                <TextBox x:Name="plcSlotBox" Grid.Column="7" Text="1" Width="30"
                         FontSize="11" FontFamily="Consolas" Background="#1A2332"
                         Foreground="#E8EDF2" BorderBrush="#253040" Padding="4,2"
                         VerticalAlignment="Center" Margin="4,0,12,0" />

                <Button x:Name="plcConnectBtn" Grid.Column="8" Content="连接 PLC"
                        FontSize="11" Padding="10,3" Background="#1A3A2A" Foreground="#80D0A0"
                        BorderBrush="#2A5A3A" Cursor="Hand"
                        VerticalAlignment="Center" HorizontalAlignment="Left"
                        Click="PlcConnect_Click" />

                <TextBlock x:Name="plcStatusText" Grid.Column="9" Text="未连接"
                           Foreground="#607080" FontSize="11" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ===== Main Content ===== -->
        <Grid Grid.Row="2" Margin="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1.3*" />
            </Grid.ColumnDefinitions>

            <!-- ============================= -->
            <!-- COLUMN 0: Process Equipment   -->
            <!-- ============================= -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="工艺设备" Style="{StaticResource SectionTitle}" />

                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,8">
                            <Grid Height="180">
                                <controls:Tank x:Name="tank" Level="65"
                                                Label="原料储罐" Capacity="2000" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,8">
                            <Grid Height="130">
                                <controls:Pump x:Name="pump" Speed="1200" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,8">
                            <Grid Height="110">
                                <controls:Motor x:Name="motor" Speed="1450" Label="驱动电机" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50" />
                                    <RowDefinition Height="50" />
                                </Grid.RowDefinitions>
                                <controls:Pipe x:Name="pipe" Grid.Row="0" IsHorizontal="True" />
                                <controls:Valve x:Name="valve" Grid.Row="1" IsOpen="True" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="DB5 数据监控" Foreground="#8899AA"
                                           FontSize="11" Margin="0,0,0,6" />
                                <ListView x:Name="plcTagList" Background="Transparent"
                                          BorderThickness="0" FontSize="10"
                                          Foreground="#E8EDF2"
                                          MaxHeight="260">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="标签名称" Width="140"
                                                DisplayMemberBinding="{Binding Name}" />
                                            <GridViewColumn Header="地址" Width="80"
                                                DisplayMemberBinding="{Binding Address}" />
                                            <GridViewColumn Header="当前值" Width="80"
                                                DisplayMemberBinding="{Binding DisplayValue}" />
                                            <GridViewColumn Header="质量" Width="50"
                                                DisplayMemberBinding="{Binding Quality}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ============================= -->
            <!-- COLUMN 1: Instruments         -->
            <!-- ============================= -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="仪表盘" Style="{StaticResource SectionTitle}" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="6" Margin="0,0,4,0">
                                <Grid Height="220">
                                    <controls:TemperatureGauge x:Name="tempGauge"
                                                                Temperature="25"
                                                                MinTemp="-20" MaxTemp="100"
                                                                HighAlarm="80" />
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="6" Margin="4,0,0,0">
                                <Grid Height="220">
                                    <controls:PressureGauge x:Name="pressGauge"
                                                             Pressure="0.5"
                                                             MaxPressure="1.6" />
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,8">
                            <Grid Height="100">
                                <controls:FlowMeter x:Name="flowMeter" FlowRate="30" MaxFlow="100" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,8">
                            <Grid Height="160">
                                <controls:ProgressRing x:Name="progressRing" Percentage="65" Label="产能利用率" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                                           Text="实时数值" Foreground="#8899AA"
                                           FontSize="11" Margin="0,0,0,6" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Foreground="#8899AA" FontSize="11">
                                    <Run Text="温度：" /><Run x:Name="tempValueText" Text="25.0 °C" Foreground="#E8EDF2" />
                                </TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="#8899AA" FontSize="11">
                                    <Run Text="压力：" /><Run x:Name="pressValueText" Text="0.50 MPa" Foreground="#E8EDF2" />
                                </TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="2" Foreground="#8899AA" FontSize="11">
                                    <Run Text="流量：" /><Run x:Name="flowValueText" Text="30.0 L/min" Foreground="#E8EDF2" />
                                </TextBlock>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ============================= -->
            <!-- COLUMN 2: Trends & Status     -->
            <!-- ============================= -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="趋势与状态" Style="{StaticResource SectionTitle}" />

                        <Border Style="{StaticResource CardBorder}" Padding="6" Margin="0,0,0,8">
                            <Grid Height="240">
                                <controls:TrendChart x:Name="trendChart"
                                                      Label="过程变量"
                                                      Unit="°C"
                                                      MinRange="0" MaxRange="100" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,8">
                            <Grid Height="90">
                                <controls:AlarmLight x:Name="alarmLight" IsAlarm="False" Label="工艺报警" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="LED 指示灯" Foreground="#8899AA" FontSize="11" Margin="0,0,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <controls:LedIndicator x:Name="ledPower" Grid.Column="0" IsOn="True"
                                                            OnColor="LimeGreen" Label="电源" />
                                    <controls:LedIndicator x:Name="ledRun" Grid.Column="1" IsOn="True"
                                                            OnColor="DodgerBlue" Label="运行" />
                                    <controls:LedIndicator x:Name="ledComm" Grid.Column="2" IsOn="True"
                                                            OnColor="Gold" Label="通讯" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="运行状态" Foreground="#8899AA" FontSize="11" Margin="0,0,0,6" />
                                <controls:StatusLabel x:Name="statusSystem" Label="系统状态"
                                                       StatusText="正常运行" Status="Normal" Margin="0,0,0,6" />
                                <controls:StatusLabel x:Name="statusProcess" Label="工艺状态"
                                                       StatusText="运行中" Status="Normal" Margin="0,0,0,6" />
                                <controls:StatusLabel x:Name="statusAlarmCtrl" Label="报警监控"
                                                       StatusText="无报警" Status="Normal" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="事件日志" Foreground="#8899AA" FontSize="11" Margin="0,0,0,6" />
                                <TextBlock x:Name="eventLog" Text="系统启动完成" Foreground="#708090" FontSize="10"
                                           TextWrapping="Wrap" MaxHeight="80" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== Status Bar ===== -->
        <Border Grid.Row="3" Background="#1A2332" BorderBrush="#253040" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse x:Name="statusBullet" Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center" />
                    <TextBlock x:Name="statusBarText" Text=" 系统运行中" Foreground="#8899AA" FontSize="11" Margin="4,0,0,0" />
                </StackPanel>

                <TextBlock x:Name="statusBarRight" Grid.Column="2"
                           Text="数据刷新率: 200ms | 连接状态: 在线"
                           Foreground="#607080" FontSize="11" />
            </Grid>
        </Border>
    </Grid>
</Window>
